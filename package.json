{
  "name": "stone-desktop",
  "version": "0.7.1",
  "private": true,
  "description": "Local-first AI gateway and coding client control center",
  "author": {
    "name": "Stone Contributors"
  },
  "license": "Apache-2.0",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:web": "vite --host 127.0.0.1 --port 5173",
    "build": "electron-vite build",
    "build:web": "vite build",
    "visual:check": "node scripts/visual-check.mjs",
    "smoke:electron": "node scripts/electron-smoke.mjs",
    "release:check": "node scripts/validate-release-tag.mjs",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run typecheck && npm test && npm run build",
    "lint": "eslint ."
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.6",
    "@fontsource-variable/jetbrains-mono": "^5.2.6",
    "fetch-socks": "^1.3.3",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "smol-toml": "^1.7.0",
    "undici": "^7.28.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^43.1.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^17.7.0",
    "playwright-core": "^1.61.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.1",
    "vite": "^6.0.7",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "io.stone.gateway",
    "productName": "Stone",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      },
      {
        "from": "LICENSE",
        "to": "LICENSE"
      },
      {
        "from": "NOTICE",
        "to": "NOTICE"
      },
      {
        "from": "THIRD_PARTY_NOTICES.md",
        "to": "THIRD_PARTY_NOTICES.md"
      }
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "artifactName": "${productName}-${version}-macos-${arch}.${ext}",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "${productName}-${version}-windows-${arch}-setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-windows-${arch}-portable.${ext}"
    },
    "linux": {
      "category": "Development",
      "icon": "build/icons",
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
